{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the project",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
        },
        "version": {
          "type": "string",
          "description": "The version of the project (semver recommended)",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$",
          "examples": ["0.1.0", "1.0.0", "2.1.0-beta.1"]
        },
        "description": {
          "type": "string",
          "description": "A brief description of the project"
        },
        "author": {
          "type": "string",
          "description": "The author of the project"
        },
        "collections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" }
            },
            "required": ["name", "path"],
            "additionalProperties": false
          }
        }
      },
      "required": ["name", "version"]
    },

    "actions": {
      "type": "object",
      "description": "Custom actions. Available variables: ${name}, ${version}, ${src}, ${out}, ${flags}",
      "properties": {
        "build": {
          "type": "string",
          "description": "Build the project",
          "default": "odin build src -out:${out}/${name} ${flags}"
        },
        "run": {
          "type": "string",
          "description": "Run the project",
          "default": "odin run src"
        },
        "check": {
          "type": "string",
          "description": "Check for errors",
          "default": "odin check src"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },

    "build": {
      "type": "object",
      "description": "Build configuration",
      "properties": {
        "src": {
          "type": "string",
          "description": "Source directory",
          "default": "src"
        },
        "out": {
          "type": "string",
          "description": "Output directory",
          "default": ".build"
        },
        "flags": {
          "type": "array",
          "description": "Additional Odin compiler flags",
          "items": {
            "type": "string"
          },
          "examples": [["-debug"], ["-o:speed", "-no-bounds-check"]]
        }
      }
    },

    "useOlsConfig": {
      "type": "boolean",
      "description": "Use ols.json for collections.",
      "default": true
    }
  },
  "required": ["project"]
}
