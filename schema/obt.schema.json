{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the project",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
      "default": "myproject"
    },

    "actions": {
      "type": "object",
      "description": "Custom actions. Available variables: ${name}, ${src}, ${out}, ${flags}",
      "properties": {
        "build": {
          "type": "string",
          "description": "Build the project",
          "default": "odin build ${src} -out:${out}/${name} ${flags}"
        },
        "run": {
          "type": "string",
          "description": "Run the project",
          "default": "odin run ${src} ${flags}"
        },
        "check": {
          "type": "string",
          "description": "Check for errors",
          "default": "odin check ${src}"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },

    "build": {
      "type": "object",
      "description": "Build configuration",
      "properties": {
        "src": {
          "type": "string",
          "description": "Source directory",
          "default": "src"
        },
        "out": {
          "type": "string",
          "description": "Output directory",
          "default": ".build"
        },
        "flags": {
          "type": "array",
          "description": "Additional Odin build flags.",
          "items": {
            "type": "string"
          },
          "examples": ["-debug", "-o:size"]
        },
        "collections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" }
            },
            "required": ["name", "path"],
            "additionalProperties": false
          }
        },
        "useOlsCollections": {
          "type": "boolean",
          "description": "Get collections from the odin language server config (ols.json).",
          "default": false
        },
        "treatOverflowAsFlags": {
          "type": "boolean",
          "description": "Treat argument overflow as build flags",
          "default": false
        }
      }
    }
  },
  "required": ["name"]
}
