{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the project",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
      "default": "myproject"
    },

    "actions": {
      "type": "object",
      "description": "Custom actions. Available placeholders: ${name}, ${src}, ${out}, ${flags}, and ${n}. look at the docs for more info.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "command": { "type": "string", "description": "Command to execute" },
          "description": { "type": "string", "description": "Description of the action" }
        },
        "required": ["command"],
        "additionalProperties": false
      }
    },


    "build": {
      "type": "object",
      "description": "Build configuration",
      "properties": {
        "src": {
          "type": "string",
          "description": "Source directory",
          "default": "src"
        },
        "out": {
          "type": "string",
          "description": "Output directory",
          "default": ".build"
        },
        "flags": {
          "type": "array",
          "description": "Additional Odin build flags.",
          "items": {
            "type": "string"
          },
          "examples": ["-debug", "-o:size"]
        },
        "collections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" }
            },
            "required": ["name", "path"],
            "additionalProperties": false
          }
        },
        "useOlsCollections": {
          "type": "boolean",
          "description": "Get collections from the odin language server config (ols.json).",
          "default": false
        }
      }
    }
  },
  "required": ["name"]
}
