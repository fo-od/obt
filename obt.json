{
  "$schema": "https://raw.githubusercontent.com/fo-od/obt/refs/heads/main/schema/obt.schema.json",
  "name": "obt",
  "actions": {
    "run": "odin run ${0}|${src} ${flags}",
    "check": "odin check ${0}|${src}",
    "build": "odin build ${0}|${src} -out:${out}/${name} ${flags}"
  },
  "build": {
    "src": "src",
    "out": ".build"
  }
}
