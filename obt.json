{
  "$schema": "https://raw.githubusercontent.com/fo-od/obt/refs/heads/main/schema/obt.schema.json",
  "name": "obt",
  "actions": {
    "build": {
      "command": "odin build ${dir} -out:${out}/${name} ${flags}",
      "args": {
        "dir": {
          "value": "${'/' in 0 ? 0 : 0/${src}}",
          "default": "${src}"
        }
      }
    }
  },
  "build": {
    "src": "src",
    "out": ".build"
  }
}
