{
  "$schema": "https://raw.githubusercontent.com/fo-od/obt/refs/heads/main/schema/obt.schema.json",
  "project": {
    "name": "obt",
    "version": "1.0.0",
    "description": "odin build tool",
    "author": "food"
  },
  "actions": {
    "run": "odin run ${src} -out:${out}/${name}",
    "check": "odin check ${src}",
    "build": "odin build ${src} -out:${out}/${name}"
  },
  "build": {
    "src": "src",
    "out": ".build"
  }
}
